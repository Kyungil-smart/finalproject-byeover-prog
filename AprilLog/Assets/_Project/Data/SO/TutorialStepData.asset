  m_Script: {fileID: 11500000, guid: 56bf0a28266a88d41b16a8563c304fc4, type: 3}
  m_Name: TutorialStepData
  m_EditorClassIdentifier: 
  _steps:
  - stepId: 0
    scene: 1
    advanceMode: 1
    gameAction: 1
    noDim: 0
    requiredSortCount: 3
    highlightTargetId: SortTable
    guideText: "\uC720\uB2DB\uC744 \uB4DC\uB798\uADF8\uD574 \uAC19\uC740 \uCC45 3\uAD8C\uC744
      \uC815\uB82C\uD574\uBCF4\uC138\uC694"
    note: "\uAE30\uD68D 2-3-2: \uC778\uD2B8\uB85C/\uC2A4\uD3F0 \uD6C4 \uC9C0\uC815
      \uB450 \uD0C0\uC77C\uC5D0 \uB4DC\uB798\uADF8 \uD654\uC0B4\uD45C \uCD9C\uB825,
      \uB4DC\uB798\uADF8\uB85C \uC815\uB82C \uC644\uC131\uD558\uBA74 \uC9C4\uD589.
      (\uC2DC\uB098\uB9AC\uC624 100026, \uBE44\uB300\uC0C1 \uD0C0\uC77C \uB524/\uC77C\uC2DC\uC815\uC9C0\uB294
      \uC2DC\uD000\uC2A4 \uB514\uB809\uD130 \uB2F4\uB2F9). \uC139\uC1581(\uC778\uD2B8\uB85C
      100001~100018\u2192\uC778\uAC8C\uC784 \uC9C4\uC785, \uBCF4\uB4DC\uC7A0\uAE08)\uC740
      \uC2DC\uC791\uD2B8\uB9AC\uAC70+\uC2DC\uB098\uB9AC\uC624\uAC00 \uCC98\uB9AC."
  - stepId: 1
    scene: 1
    advanceMode: 1
    gameAction: 0
    noDim: 0
    highlightTargetId: 
    guideText: "\uC815\uB82C\uD558\uBA74 \uACF5\uACA9\uC774 \uB098\uAC11\uB2C8\uB2E4!
      \uBAAC\uC2A4\uD130\uB97C \uCC98\uCE58\uD574 \uACBD\uD5D8\uCE58\uB97C \uBAA8\uC73C\uC138\uC694"
    note: "\uAE30\uD68D 3: \uCD5C\uCD08 \uACF5\uACA9 \uACA9\uBC1C + \uACBD\uD5D8\uCE58
      \uD68D\uB4DD \uC5F0\uC2B5. \uBC18\uBCF5 \uC815\uB82C\uB85C \uC9C4\uD589. (\uC2DC\uB098\uB9AC\uC624
      100027~100029, \uCF64\uBCF4 UI \uAC00\uC774\uB4DC)"
  - stepId: 2
    scene: 1
    advanceMode: 0
    gameAction: 0
    noDim: 0
    highlightTargetId: EnchantCard
    guideText: "\uC778\uCC48\uD2B8 \uCE74\uB4DC\uB97C \uC120\uD0DD\uD558\uC138\uC694"
    note: "\uAE30\uD68D 4: \uCD5C\uCD08 \uB808\uBCA8\uC5C5 \uC989\uC2DC \uC77C\uC2DC\uC815\uC9C0
      + \uC778\uCC48\uD2B8 \uD31D\uC5C5(\uACE0\uC815 3\uCE74\uB4DC: \uC790\uB3D9\uACF5\uACA9/\uC870\uD569\uD615/\uCF64\uBCF4\uD615).
      \uC2DC\uB098\uB9AC\uC624 100030~100034. \uB808\uBCA8\uC5C5 \uACA9\uBC1C=GameAction\uC774\uB098
      \uCE74\uB4DC \uC120\uD0DD\uC740 \uD0ED. \uD31D\uC5C5/\uC77C\uC2DC\uC815\uC9C0
      \uC81C\uC5B4=\uC2DC\uD000\uC2A4 \uB514\uB809\uD130."
  - stepId: 3
    scene: 1
    advanceMode: 1
    gameAction: 0
    noDim: 0
    highlightTargetId: 
    guideText: "\uC870\uD569\xB7\uCF64\uBCF4 \uC2A4\uD0AC\uB85C \uD2B9\uC218\uC6E8\uC774\uBE0C\uB97C
      \uB9C9\uC544\uBCF4\uC138\uC694"
    note: "\uAE30\uD68D 5: \uC778\uCC48\uD2B8 \uD6C4 1\uC6E8\uC774\uBE0C \uB4A4 \uD2B9\uC218\uC6E8\uC774\uBE0C
      \uBAAC\uC2A4\uD130 \uB7EC\uC2DC \u2192 \uAC15\uC81C \uD328\uBC30(HP0). \uC2DC\uB098\uB9AC\uC624
      100036~100039 \uD6C4 \uB85C\uBE44 \uBCF5\uADC0(\uB85C\uBE44 \uB2E8\uACC41 \uC138\uD305).
      \uAC15\uC81C\uD328\uBC30 \uC5F0\uCD9C=\uC2DC\uD000\uC2A4 \uB514\uB809\uD130."
  - stepId: 4
    scene: 0
    advanceMode: 0
    gameAction: 0
    noDim: 0
    highlightTargetId: CharacterGrowthButton
    guideText: "\uCE90\uB9AD\uD130 \uC131\uC7A5\uC73C\uB85C \uB354 \uAC15\uD574\uC9C0\uC138\uC694"
    note: "\uAE30\uD68D 6: \uAC15\uC81C\uD328\uBC30 \uD6C4 \uB85C\uBE44 \uBCF5\uADC0.
      \uD558\uB2E8\uBC14 + \uC131\uC7A5/\uC804\uD22C \uBC84\uD2BC\uB9CC \uB178\uCD9C(\uB85C\uBE44
      \uB2E8\uACC41, \uADF8 \uC678 \uC7A0\uAE08). \uC2DC\uB098\uB9AC\uC624 100041~100043."
  - stepId: 5
    scene: 0
    advanceMode: 0
    gameAction: 0
    noDim: 0
    highlightTargetId: LevelUpButton
    guideText: "\uB808\uBCA8\uC5C5 \uBC84\uD2BC\uC744 \uB20C\uB7EC \uB2A5\uB825\uCE58\uB97C
      \uC62C\uB9AC\uC138\uC694"
    note: "\uAE30\uD68D 6-3-2: \uB808\uBCA8\uC5C5 \uBC84\uD2BC \uAC00\uC774\uB4DC.
      \uC2DC\uB098\uB9AC\uC624 100045~100051."
  - stepId: 6
    scene: 0
    advanceMode: 0
    gameAction: 0
    noDim: 0
    highlightTargetId: ShopButton
    guideText: "\uC0C1\uC810\uC73C\uB85C \uC774\uB3D9\uD574\uBCF4\uC138\uC694"
    note: "\uAE30\uD68D 7-3-1: \uC544\uD2F0\uD329\uD2B8 \uC0C1\uC810 \uC9C4\uC785.
      \uC2DC\uB098\uB9AC\uC624 100052~100055. \uD29C\uD1A0\uC6A9 \uBF51\uAE30\uAD8C
      1\uAC1C \uC9C0\uAE09."
  - stepId: 7
    scene: 0
    advanceMode: 0
    gameAction: 0
    noDim: 0
    highlightTargetId: GachaButton
    guideText: "\uC544\uD2F0\uD329\uD2B8\uB97C \uBF51\uC544\uBCF4\uC138\uC694"
    note: "\uAE30\uD68D 7-3-2: \uBF51\uAE30. \uC2DC\uB098\uB9AC\uC624 100056~100057
      \uD6C4 \uC131\uC7A5 \uBC84\uD2BC \uB524+\uC190\uAC00\uB77D \uAC00\uC774\uB4DC."
  - stepId: 8
    scene: 0
    advanceMode: 0
    gameAction: 0
    noDim: 1
    highlightTargetId: GachaConfirmButton
    guideText: "\uD655\uC778\uC744 \uB20C\uB7EC \uACB0\uACFC\uB97C \uB2EB\uC73C\uC138\uC694"
    note: "\uAE30\uD68D 7-3-1-5: \uBF51\uAE30 \uACB0\uACFC \uD655\uC778. \uACB0\uACFC\uCC3D\uC744
      \uAC00\uB9AC\uC9C0 \uC54A\uAC8C \uB524 \uB054."
  - stepId: 9
    scene: 0
    advanceMode: 0
    gameAction: 0
    noDim: 0
    highlightTargetId: CharacterGrowthButton
    guideText: "\uCE90\uB9AD\uD130 \uC131\uC7A5\uC73C\uB85C \uC774\uB3D9\uD558\uC138\uC694"
    note: "\uAE30\uD68D 7-3-1-6: \uCE90\uB9AD\uD130 \uC131\uC7A5 \uD654\uBA74 \uC9C4\uC785."
  - stepId: 10
    scene: 0
    advanceMode: 0
    gameAction: 0
    noDim: 0
    highlightTargetId: ArtifactGrowthButton
    guideText: "\uC544\uD2F0\uD329\uD2B8 \uD0ED\uC744 \uC120\uD0DD\uD558\uC138\uC694"
    note: "\uAE30\uD68D 7-3-2: \uC544\uD2F0\uD329\uD2B8 \uD654\uBA74 \uC804\uD658."
  - stepId: 11
    scene: 0
    advanceMode: 1
    gameAction: 3
    noDim: 1
    highlightTargetId: ArtifactList
    guideText: "\uBF51\uC740 \uC544\uD2F0\uD329\uD2B8\uB97C \uB20C\uB7EC \uC0C1\uC138\uCC3D\uC744
      \uC5EC\uC138\uC694"
    note: "\uAE30\uD68D 7-3-2-3: \uBCF4\uC720 \uC544\uD2F0\uD329\uD2B8 \uC120\uD0DD.
      \uBAA9\uB85D \uC190\uAC00\uB77D, \uC0C1\uC138\uCC3D \uC5F4\uB9AC\uBA74 \uC9C4\uD589.
      \uB524 \uB054."
  - stepId: 12
    scene: 0
    advanceMode: 1
    gameAction: 2
    noDim: 1
    highlightTargetId: ArtifactLevelUpButton
    guideText: "5\uB808\uBCA8\uAE4C\uC9C0 \uAC15\uD654, \uB3CC\uD30C\uD558\uACE0
      \uC7A5\uCC29\uD558\uC138\uC694"
    note: "\uAE30\uD68D 7-3-2~3: \uB808\uBCA8\uC5C5 5\uD68C+\uB3CC\uD30C+\uC7A5\uCC29.
      \uB808\uBCA8\uC5C5 \uBC84\uD2BC \uC190\uAC00\uB77D, \uC7A5\uCC29 \uC2DC \uC9C4\uD589.
      \uB524 \uB054."
  - stepId: 13
    scene: 0
    advanceMode: 0
    gameAction: 0
    noDim: 0
    highlightTargetId: StageStartButton
    guideText: "\uB2E4\uC2DC \uC804\uD22C\uB97C \uC2DC\uC791\uD574 \uC131\uC7A5\uC744
      \uCCB4\uAC10\uD558\uC138\uC694"
    note: "\uAE30\uD68D 8: \uC131\uC7A5 \uC644\uB8CC \uD6C4 0-1\uCC55\uD130 \uC7AC\uC9C4\uC785(\uC720\uC800\uC5D0\uAC90
      \uAC19\uC740 0\uCC55\uD130, \uD29C\uD1A0 \uC124\uBA85 \uC5C6\uB294 \uBC84\uC804)."
  - stepId: 14
    scene: 1
    advanceMode: 1
    gameAction: 4
    noDim: 0
    highlightTargetId: 
    guideText: "\uBCF4\uC2A4\uB97C \uCC98\uCE58\uD558\uACE0 0\uCC55\uD130\uB97C \uD074\uB9AC\uC5B4\uD558\uC138\uC694!"
    note: "\uAE30\uD68D 9: \uBCF4\uC2A4 \uD074\uB9AC\uC5B4 + \uC2B9\uB9AC \uBCF4\uC0C1.
      (\uAE30\uD68D 10\xB711 = \uB85C\uBE44 \uB2E8\uACC43 UI \uD574\uAE08, \uBCC4\uB3C4)"

  m_Script: {fileID: 11500000, guid: 1ccbcc63887cb634cbaf2b4da4deab5e, type: 3}
  m_Name: UILocalizationTable
  m_EditorClassIdentifier: Assembly-CSharp::UILocalizationTable
  rows:
  - Language_ID: 11000
    KR: "  \"content\": \"\uAC1C\uC778\uC815\uBCF4 \uCC98\uB9AC\uBC29\uCE68\\n\\n\uC2DC\uD589\uC77C\uC790:
      2025\uB144 09\uC6D4 17\uC77C\\n\\n\uB514\uBCA8\uB85C\uCF13 \uC5D0\uB4C0 (\uC774\uD558
      \\\"\uD68C\uC0AC\\\")\uB294 \uADC0\uD558\uC758 \uAC1C\uC778\uC815\uBCF4\uB97C
      \uB9E4\uC6B0 \uC911\uC694\uD558\uAC8C \uC0DD\uAC01\uD558\uBA70, \\\"\uC815\uBCF4\uD1B5\uC2E0\uB9DD
      \uC774\uC6A9\uCD09\uC9C4 \uBC0F \uC815\uBCF4\uBCF4\uD638 \uB4F1\uC5D0 \uAD00\uD55C
      \uBC95\uB960\\\", \\\"\uAC1C\uC778\uC815\uBCF4\uBCF4\uD638\uBC95\\\" \uB4F1
      \uAD00\uB828 \uBC95\uB839\uC0C1\uC758 \uAC1C\uC778\uC815\uBCF4\uBCF4\uD638
      \uADDC\uC815\uC744 \uC900\uC218\uD558\uACE0 \uC788\uC2B5\uB2C8\uB2E4.\\n\\n\uD68C\uC0AC\uB294
      \uBCF8 \uAC1C\uC778\uC815\uBCF4 \uCC98\uB9AC\uBC29\uCE68\uC744 \uD1B5\uD558\uC5EC
      \uADC0\uD558\uAED8\uC11C \uC81C\uACF5\uD558\uC2DC\uB294 \uAC1C\uC778\uC815\uBCF4\uAC00
      \uC5B4\uB5A0\uD55C \uC6A9\uB3C4\uC640 \uBC29\uC2DD\uC73C\uB85C \uC774\uC6A9\uB418\uACE0
      \uC788\uC73C\uBA70, \uAC1C\uC778\uC815\uBCF4\uBCF4\uD638\uB97C \uC704\uD574
      \uC5B4\uB5A0\uD55C \uC870\uCE58\uAC00 \uCDE8\uD574\uC9C0\uACE0 \uC788\uB294\uC9C0
      \uC54C\uB824\uB4DC\uB9BD\uB2C8\uB2E4. \uBCF8 \uBC29\uCE68\uC740 \uBC95\uB839
      \uBC0F \uC815\uBD80\uC9C0\uCE68\uC758 \uBCC0\uACBD\uACFC \uC11C\uBE44\uC2A4
      \uC6B4\uC601 \uBC29\uCE68\uC5D0 \uB530\uB77C \uBCC0\uACBD\uB420 \uC218 \uC788\uC2B5\uB2C8\uB2E4.\\n\\n\uC81C1\uC870
      (\uAC1C\uC778\uC815\uBCF4\uC758 \uC218\uC9D1 \uD56D\uBAA9 \uBC0F \uC218\uC9D1
      \uBC29\uBC95)\\n\\n1. \uC218\uC9D1\uD558\uB294 \uAC1C\uC778\uC815\uBCF4\uC758
      \uD56D\uBAA9\\n\\n\uAC00. \uD68C\uC6D0\uAC00\uC785 \uBC0F \uACC4\uC815 \uC5F0\uB3D9
      \uC2DC\\n\\n- \uC774\uBA54\uC77C \uACC4\uC815\uC73C\uB85C \uAC00\uC785 \uC2DC:
      \uC774\uBA54\uC77C \uC8FC\uC18C, \uBE44\uBC00\uBC88\uD638(\uC554\uD638\uD654
      \uC800\uC7A5), \uB2C9\uB124\uC784\\n\\n- \uC18C\uC15C \uB85C\uADF8\uC778(SNS
      \uACC4\uC815 \uC5F0\uB3D9) \uC2DC: \uAC01 \uD50C\uB7AB\uD3FC\uC5D0\uC11C \uC81C\uACF5\uD558\uB294
      \uBC94\uC704 \uB0B4\uC5D0\uC11C \uB2E4\uC74C \uC815\uBCF4\uB97C \uC218\uC9D1\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4.\\n\\n  * \uACF5\uD1B5 \uD56D\uBAA9: \uC774\uC6A9\uC790
      \uC2DD\uBCC4 \uACE0\uC720 \uC815\uBCF4(User ID), \uB2C9\uB124\uC784, \uD504\uB85C\uD544
      \uC0AC\uC9C4\\n\\n  * Google \uB85C\uADF8\uC778: \uC774\uBA54\uC77C \uC8FC\uC18C\\n\\n 
      * Facebook \uB85C\uADF8\uC778: \uC774\uBA54\uC77C \uC8FC\uC18C\\n\\n  * Apple
      \uB85C\uADF8\uC778: \uC774\uBA54\uC77C \uC8FC\uC18C (\uBE44\uACF5\uAC1C \uC774\uBA54\uC77C
      \uC8FC\uC18C \uD3EC\uD568)\\n\\n  * \uCE74\uCE74\uC624 \uB85C\uADF8\uC778:
      \uCE74\uCE74\uC624\uACC4\uC815(\uC774\uBA54\uC77C), \uB2C9\uB124\uC784, \uD504\uB85C\uD544
      \uC0AC\uC9C4\\n\\n  * \uD1A0\uC2A4 \uB85C\uADF8\uC778: \uC774\uBA54\uC77C \uC8FC\uC18C\\n\\n-
      \uCC38\uACE0: \uD68C\uC0AC\uB294 \uADC0\uD558\uC758 \uC18C\uC15C \uB85C\uADF8\uC778
      \uBE44\uBC00\uBC88\uD638\uB97C \uC808\uB300 \uC218\uC9D1\uD558\uAC70\uB098
      \uC800\uC7A5\uD558\uC9C0 \uC54A\uC2B5\uB2C8\uB2E4.\\n\\n\uB098. \uAC8C\uC784
      \uC11C\uBE44\uC2A4 \uC774\uC6A9 \uACFC\uC815\uC5D0\uC11C \uC790\uB3D9 \uC0DD\uC131
      \uBC0F \uC218\uC9D1\uB418\uB294 \uC815\uBCF4\\n\\n- \uAE30\uAE30 \uC815\uBCF4:
      \uAE30\uAE30 \uBAA8\uB378\uBA85, OS \uC885\uB958 \uBC0F \uBC84\uC804, \uD654\uBA74
      \uD574\uC0C1\uB3C4, \uD1B5\uC2E0\uC0AC \uC815\uBCF4\\n\\n- \uACE0\uC720 \uC2DD\uBCC4
      \uC815\uBCF4: \uAD11\uACE0 \uC2DD\uBCC4\uC790(IDFA, AAID), \uAE30\uAE30 \uACE0\uC720
      \uBC88\uD638(UDID, IMEI \uB4F1)\\n\\n- \uB124\uD2B8\uC6CC\uD06C \uC815\uBCF4:
      IP \uC8FC\uC18C, \uC811\uC18D \uAD6D\uAC00 \uC815\uBCF4, \uB124\uD2B8\uC6CC\uD06C
      \uC885\uB958(Wi-Fi, LTE \uB4F1)\\n\\n- \uAC8C\uC784 \uC774\uC6A9 \uAE30\uB85D:
      \uAC8C\uC784 \uBC84\uC804, \uAC8C\uC784 \uD50C\uB808\uC774 \uAE30\uB85D(\uB808\uBCA8,
      \uC7AC\uD654, \uC544\uC774\uD15C \uB4F1), \uC811\uC18D \uC2DC\uAC04 \uBC0F
      \uC811\uC18D \uC77C\uC790, \uBE44\uC815\uC0C1\uC801 \uC774\uC6A9 \uAE30\uB85D,
      \uC778\uAC8C\uC784 \uCC44\uD305 \uAE30\uB85D\\n\\n- \uC624\uB958 \uC815\uBCF4:
      \uAC8C\uC784 \uC2E4\uD589 \uC911 \uBC1C\uC0DD\uD558\uB294 \uC5D0\uB7EC \uBC0F
      \uD06C\uB798\uC2DC \uB85C\uADF8 \uB370\uC774\uD130\\n\\n\uB2E4. \uC720\uB8CC
      \uC11C\uBE44\uC2A4 \uC774\uC6A9 \uC2DC\\n\\n- \uD68C\uC0AC\uB294 \uACB0\uC81C
      \uACFC\uC815\uC5D0\uC11C \uC2E0\uC6A9\uCE74\uB4DC \uBC88\uD638 \uB4F1 \uBBFC\uAC10\uD55C
      \uACB0\uC81C \uC815\uBCF4\uB97C \uC9C1\uC811 \uC218\uC9D1 \uBC0F \uC800\uC7A5\uD558\uC9C0
      \uC54A\uC2B5\uB2C8\uB2E4. \uACB0\uC81C\uB294 Google Play \uB4F1 \uC571 \uB9C8\uCF13
      \uD50C\uB7AB\uD3FC\uC758 \uACB0\uC81C \uBAA8\uB4C8\uC744 \uD1B5\uD574 \uC774\uB8E8\uC5B4\uC9C0\uBA70,
      \uD68C\uC0AC\uB294 \uACB0\uC81C \uAC80\uC99D\uC744 \uC704\uD574 \uD50C\uB7AB\uD3FC\uC73C\uB85C\uBD80\uD130
      \uACB0\uC81C \uC601\uC218\uC99D(\uAC70\uB798 ID, \uAD6C\uB9E4 \uB0B4\uC5ED
      \uB4F1) \uC815\uBCF4\uB9CC\uC744 \uC804\uB2EC\uBC1B\uC2B5\uB2C8\uB2E4.\\n\\n\uB77C.
      \uACE0\uAC1D \uC9C0\uC6D0 \uBC0F \uC774\uBCA4\uD2B8 \uCC38\uC5EC \uC2DC\\n\\n-
      \uBB38\uC758 \uC811\uC218 \uC2DC: \uC774\uBA54\uC77C \uC8FC\uC18C, \uD734\uB300\uC804\uD654
      \uBC88\uD638, \uB2C9\uB124\uC784, \uBB38\uC758 \uBC0F \uB2F5\uBCC0 \uB0B4\uC6A9\\n\\n-
      \uACBD\uD488 \uBC1C\uC1A1 \uC2DC: \uC774\uB984, \uD734\uB300\uC804\uD654 \uBC88\uD638,
      \uC8FC\uC18C (\uC218\uC9D1 \uC2DC \uBCC4\uB3C4 \uB3D9\uC758)\\n\\n  1. \uAC1C\uC778\uC815\uBCF4
      \uC218\uC9D1 \uBC29\uBC95\\n\\n    - \uC774\uC6A9\uC790\uAC00 \uC9C1\uC811
      \uC785\uB825 \uBC0F \uB3D9\uC758 (\uD68C\uC6D0\uAC00\uC785, \uC11C\uBE44\uC2A4
      \uC774\uC6A9 \uB4F1)\\n\\n    - \uC18C\uC15C \uB85C\uADF8\uC778 \uD50C\uB7AB\uD3FC\uC73C\uB85C\uBD80\uD130
      \uC815\uBCF4 \uC81C\uACF5\\n\\n    - \uACE0\uAC1D\uC13C\uD130 \uBB38\uC758,
      \uC774\uBCA4\uD2B8 \uC751\uBAA8\\n\\n    - \uC11C\uBE44\uC2A4 \uC774\uC6A9
      \uACFC\uC815\uC5D0\uC11C \uC815\uBCF4 \uC790\uB3D9 \uC0DD\uC131 \uBC0F \uC218\uC9D1\\n\\n\uC81C2\uC870
      (\uAC1C\uC778\uC815\uBCF4\uC758 \uC218\uC9D1 \uBC0F \uC774\uC6A9 \uBAA9\uC801)\\n\\n-
      \uD68C\uC6D0 \uAD00\uB9AC: \uBCF8\uC778 \uC2DD\uBCC4, \uBD80\uC815 \uC774\uC6A9
      \uBC29\uC9C0, \uBD84\uC7C1 \uC870\uC815, \uBBFC\uC6D0 \uCC98\uB9AC \uB4F1\\n\\n-
      \uC11C\uBE44\uC2A4 \uC81C\uACF5: \uCF58\uD150\uCE20 \uC81C\uACF5, \uC720\uB8CC
      \uC11C\uBE44\uC2A4 \uACB0\uC81C \uBC0F \uC815\uC0B0, \uACF5\uC9C0\uC0AC\uD56D
      \uC804\uB2EC\\n\\n- \uC11C\uBE44\uC2A4 \uAC1C\uC120: \uC774\uC6A9 \uD1B5\uACC4
      \uBD84\uC11D, \uC11C\uBE44\uC2A4 \uC548\uC815\uC131 \uD655\uBCF4, \uC2E0\uADDC
      \uC11C\uBE44\uC2A4 \uAC1C\uBC1C\\n\\n- \uB9C8\uCF00\uD305 \uBC0F \uAD11\uACE0:
      \uC774\uBCA4\uD2B8 \uC815\uBCF4 \uC548\uB0B4, \uB9DE\uCDA4\uD615 \uAD11\uACE0
      \uC81C\uACF5 (\uC218\uC2E0 \uB3D9\uC758\uC790\uC5D0 \uD55C\uD568)\\n\\n- \uBCF4\uC548
      \uBC0F \uC548\uC815\uC131: \uACC4\uC815 \uB3C4\uC6A9 \uBC0F \uBE44\uC815\uC0C1
      \uC774\uC6A9 \uD589\uC704 \uBC29\uC9C0\\n\\n\uC81C3\uC870 (\uAC1C\uC778\uC815\uBCF4\uC758
      \uC81C3\uC790 \uC81C\uACF5)\\n\\n\uD68C\uC0AC\uB294 \uC774\uC6A9\uC790\uC758
      \uC0AC\uC804 \uB3D9\uC758 \uC5C6\uC774 \uAC1C\uC778\uC815\uBCF4\uB97C \uC678\uBD80\uC5D0
      \uC81C\uACF5\uD558\uC9C0 \uC54A\uC2B5\uB2C8\uB2E4. \uB2E8, \uBC95\uB839\uC5D0
      \uADDC\uC815\uC774 \uC788\uAC70\uB098 \uC218\uC0AC\uAE30\uAD00\uC758 \uBC95\uC801
      \uC808\uCC28\uC5D0 \uB530\uB978 \uC694\uAD6C\uAC00 \uC788\uB294 \uACBD\uC6B0\uB294
      \uC608\uC678\uB85C \uD569\uB2C8\uB2E4.\\n\\n\uC81C4\uC870 (\uAC1C\uC778\uC815\uBCF4
      \uCC98\uB9AC\uC758 \uC704\uD0C1)\\n\\n\uD68C\uC0AC\uB294 \uC6D0\uD65C\uD55C
      \uC11C\uBE44\uC2A4 \uC81C\uACF5\uC744 \uC704\uD574 \uC544\uB798\uC640 \uAC19\uC774
      \uAC1C\uC778\uC815\uBCF4 \uCC98\uB9AC \uC5C5\uBB34\uB97C \uC678\uBD80 \uC804\uBB38\uC5C5\uCCB4\uC5D0
      \uC704\uD0C1\uD569\uB2C8\uB2E4.\\n\\nGoogle Cloud: \uB370\uC774\uD130 \uBCF4\uAD00
      \uBC0F \uC11C\uBC84 \uC6B4\uC601 \uAD00\uB9AC\\n\\nGoogle Analytics, Firebase:
      \uAC8C\uC784 \uC774\uC6A9 \uD589\uD0DC \uBD84\uC11D \uBC0F \uD1B5\uACC4 \uCC98\uB9AC\\n\\n\uB514\uBCA8\uB85C\uCF13
      \uC5D0\uB4C0: \uACE0\uAC1D \uBB38\uC758 \uC751\uB300 \uBC0F \uC548\uB0B4\\n\\n\uC81C5\uC870
      (\uAC1C\uC778\uC815\uBCF4\uC758 \uBCF4\uC720 \uBC0F \uC774\uC6A9\uAE30\uAC04)\\n\\n\uAC1C\uC778\uC815\uBCF4\uB294
      \uBAA9\uC801 \uB2EC\uC131 \uC2DC \uC9C0\uCCB4 \uC5C6\uC774 \uD30C\uAE30\uD558\uB098,
      \uC544\uB798\uC640 \uAC19\uC774 \uAD00\uACC4\uBC95\uB839\uC5D0 \uB530\uB77C
      \uBCF4\uC874\uD560 \uD544\uC694\uAC00 \uC788\uB294 \uACBD\uC6B0 \uBA85\uC2DC\uB41C
      \uAE30\uAC04 \uB3D9\uC548 \uBCF4\uAD00\uD569\uB2C8\uB2E4.\\n\\n- \uACC4\uC57D
      \uB610\uB294 \uCCAD\uC57D\uCCA0\uD68C \uB4F1\uC5D0 \uAD00\uD55C \uAE30\uB85D:
      5\uB144\\n\\n- \uB300\uAE08\uACB0\uC81C \uBC0F \uC7AC\uD654 \uB4F1\uC758 \uACF5\uAE09\uC5D0
      \uAD00\uD55C \uAE30\uB85D: 5\uB144\\n\\n- \uC18C\uBE44\uC790\uC758 \uBD88\uB9CC
      \uB610\uB294 \uBD84\uC7C1\uCC98\uB9AC\uC5D0 \uAD00\uD55C \uAE30\uB85D: 3\uB144\\n\\n-
      \uB85C\uADF8\uC778 \uAE30\uB85D: 3\uAC1C\uC6D4\\n\\n\uC81C6\uC870 (\uAC1C\uC778\uC815\uBCF4\uC758
      \uD30C\uAE30\uC808\uCC28 \uBC0F \uBC29\uBC95)\\n\\n\uBCF4\uC720 \uAE30\uAC04\uC774
      \uACBD\uACFC\uD55C \uAC1C\uC778\uC815\uBCF4\uB294 \uC7AC\uC0DD \uBD88\uAC00\uB2A5\uD55C
      \uAE30\uC220\uC801 \uBC29\uBC95\uC744 \uC0AC\uC6A9\uD558\uC5EC \uC0AD\uC81C\uD558\uACE0,
      \uC885\uC774 \uBB38\uC11C\uB294 \uBD84\uC1C4 \uB610\uB294 \uC18C\uAC01\uD558\uC5EC
      \uD30C\uAE30\uD569\uB2C8\uB2E4.\\n\\n\uC81C7\uC870 (\uC774\uC6A9\uC790 \uBC0F
      \uBC95\uC815\uB300\uB9AC\uC778\uC758 \uAD8C\uB9AC \uBC0F \uADF8 \uD589\uC0AC\uBC29\uBC95)\\n\\n\uC774\uC6A9\uC790(\uBC0F
      \uB9CC 14\uC138 \uBBF8\uB9CC \uC544\uB3D9\uC758 \uBC95\uC815\uB300\uB9AC\uC778)\uB294
      \uC5B8\uC81C\uB4E0\uC9C0 \uAC1C\uC778\uC815\uBCF4\uB97C \uC870\uD68C, \uC218\uC815,
      \uC0AD\uC81C(\uD68C\uC6D0\uD0C8\uD1F4)\uD560 \uC218 \uC788\uC73C\uBA70, \uAC8C\uC784
      \uB0B4 \uC124\uC815 \uAE30\uB2A5 \uB610\uB294 \uAC1C\uC778\uC815\uBCF4 \uBCF4\uD638\uCC45\uC784\uC790\uB97C
      \uD1B5\uD574 \uC694\uCCAD\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4.\\n\\n\uC81C8\uC870
      (\uAC1C\uC778\uC815\uBCF4 \uC790\uB3D9 \uC218\uC9D1 \uC7A5\uCE58\uC758 \uC124\uCE58\xB7\uC6B4\uC601
      \uBC0F \uADF8 \uAC70\uBD80\uC5D0 \uAD00\uD55C \uC0AC\uD56D)\\n\\n\uC774\uC6A9\uC790\uB294
      \uAE30\uAE30 \uC124\uC815 \uBCC0\uACBD\uC744 \uD1B5\uD574 \uB9DE\uCDA4\uD615
      \uAD11\uACE0\uB97C \uC704\uD55C \uAD11\uACE0 \uC2DD\uBCC4\uC790(IDFA, AAID)
      \uC218\uC9D1\uC744 \uAC70\uBD80\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4.\\n\\n-
      Android: \uC124\uC815 \u2192 Google \u2192 \uAD11\uACE0 \u2192 \uAD11\uACE0
      ID \uC7AC\uC124\uC815 \uB610\uB294 \uAD11\uACE0 \uB9DE\uCDA4\uC124\uC815 \uC120\uD0DD
      \uD574\uC81C\\n\\n- iOS: \uC124\uC815 \u2192 \uAC1C\uC778\uC815\uBCF4\uBCF4\uD638
      \u2192 \uCD94\uC801 \u2192 \uC571\uC774 \uCD94\uC801\uC744 \uC694\uCCAD\uD558\uB3C4\uB85D
      \uD5C8\uC6A9 \uB044\uAE30\\n\\n\uC81C9\uC870 (\uAC1C\uC778\uC815\uBCF4\uC758
      \uC548\uC804\uC131 \uD655\uBCF4 \uC870\uCE58)\\n\\n\uD68C\uC0AC\uB294 \uBE44\uBC00\uBC88\uD638
      \uC554\uD638\uD654, \uD574\uD0B9 \uB300\uBE44 \uAE30\uC220\uC801 \uB300\uCC45,
      \uAC1C\uC778\uC815\uBCF4 \uCC98\uB9AC \uC9C1\uC6D0\uC758 \uCD5C\uC18C\uD654
      \uBC0F \uAD50\uC721 \uB4F1 \uAD00\uB9AC\uC801\xB7\uAE30\uC220\uC801 \uC870\uCE58\uB97C
      \uD1B5\uD574 \uC774\uC6A9\uC790\uC758 \uAC1C\uC778\uC815\uBCF4\uB97C \uC548\uC804\uD558\uAC8C
      \uBCF4\uD638\uD569\uB2C8\uB2E4.\\n\\n\uC81C10\uC870 (\uAC1C\uC778\uC815\uBCF4
      \uBCF4\uD638\uCC45\uC784\uC790)\\n\\n- \uC774\uB984: \uC591\uD604\uC11D\\n\\n-
      \uC18C\uC18D: \uB514\uBCA8\uB85C\uCF13 \uC5D0\uB4C0\\n\\n- \uC9C1\uCC45: \uCC28\uC7A5\\n\\n-
      \uC774\uBA54\uC77C: smart@kiweb.or.kr\\n\\n- \uC804\uD654\uBC88\uD638: 02-479-4050\\n\\n\uC81C11\uC870
      (\uACE0\uC9C0\uC758 \uC758\uBB34)\\n\\n\uD604 \uAC1C\uC778\uC815\uBCF4 \uCC98\uB9AC\uBC29\uCE68\uC758
      \uB0B4\uC6A9 \uCD94\uAC00, \uC0AD\uC81C \uBC0F \uC218\uC815\uC774 \uC788\uC744
      \uC2DC\uC5D0\uB294 \uAC1C\uC815 \uCD5C\uC18C 7\uC77C \uC804\uBD80\uD130 \uAC8C\uC784
      \uB0B4 \uACF5\uC9C0\uC0AC\uD56D \uB4F1\uC744 \uD1B5\uD558\uC5EC \uACE0\uC9C0\uD560
      \uAC83\uC785\uB2C8\uB2E4.\\n\\n- \uACF5\uACE0\uC77C\uC790: 2025\uB144 09\uC6D4
      17\uC77C\\n\\n- \uC2DC\uD589\uC77C\uC790: 2025\uB144 09\uC6D4 17\uC77C\""
    EN: "\"content\": \"Privacy Policy\\n\\nEffective Date: September 17, 2025\\n\\nDevelopocket
      Edu (the \\\"Company\\\") places great importance on your personal information
      and complies with the personal information protection provisions under relevant
      laws, including the \\\"Act on Promotion of Information and Communications
      Network Utilization and Information Protection\\\" and the \\\"Personal Information
      Protection Act.\\\"\\n\\nThrough this Privacy Policy, the Company informs you
      of the purposes and methods for which the personal information you provide
      is used, as well as the measures taken to protect your personal information.
      This Policy may be changed in accordance with changes in laws, government guidelines,
      and service operation policies.\\n\\nArticle 1 (Items and Methods of Personal
      Information Collection)\\n\\n1. Items of Personal Information Collected\\n\\na.
      At Sign-up and Account Linking\\n\\n- When signing up with an email account:
      Email address, password (stored encrypted), nickname\\n\\n- When signing up
      via social login (SNS account linking): The following information may be collected
      within the scope provided by each platform.\\n\\n  * Common items: User's unique
      identification information (User ID), nickname, profile photo\\n\\n  * Google
      login: Email address\\n\\n  * Facebook login: Email address\\n\\n  * Apple
      login: Email address (including private relay email address)\\n\\n  * Kakao
      login: Kakao account (email), nickname, profile photo\\n\\n  * Toss login:
      Email address\\n\\n- Note: The Company never collects or stores your social
      login password.\\n\\nb. Information Automatically Generated and Collected While
      Using the Game Service\\n\\n- Device information: Device model name, OS type
      and version, screen resolution, carrier information\\n\\n- Unique identification
      information: Advertising identifiers (IDFA, AAID), device unique numbers (UDID,
      IMEI, etc.)\\n\\n- Network information: IP address, access country information,
      network type (Wi-Fi, LTE, etc.)\\n\\n- Game usage records: Game version, gameplay
      records (level, currency, items, etc.), access time and date, records of abnormal
      usage, in-game chat records\\n\\n- Error information: Error and crash log data
      generated while the game is running\\n\\nc. When Using Paid Services\\n\\n-
      The Company does not directly collect or store sensitive payment information
      such as credit card numbers during the payment process. Payments are made through
      the payment module of app market platforms such as Google Play, and the Company
      only receives payment receipt information (transaction ID, purchase details,
      etc.) from the platform for payment verification purposes.\\n\\nd. Customer
      Support and Event Participation\\n\\n- When submitting an inquiry: Email address,
      mobile phone number, nickname, inquiry and response content\\n\\n- When sending
      a prize: Name, mobile phone number, address (separate consent obtained upon
      collection)\\n\\n  1. Methods of Personal Information Collection\\n\\n    -
      Directly entered and consented to by the user (sign-up, service use, etc.)\\n\\n   
      - Provided by social login platforms\\n\\n    - Customer center inquiries,
      event applications\\n\\n    - Automatically generated and collected during
      service use\\n\\nArticle 2 (Purposes of Collection and Use of Personal Information)\\n\\n-
      Member management: Identity verification, prevention of fraudulent use, dispute
      resolution, complaint handling, etc.\\n\\n- Service provision: Content provision,
      paid service payment and settlement, notice delivery\\n\\n- Service improvement:
      Usage statistics analysis, service stability assurance, new service development\\n\\n-
      Marketing and advertising: Event information notification, personalized advertising
      (only for those who consented to receive it)\\n\\n- Security and stability:
      Prevention of account theft and abnormal use\\n\\nArticle 3 (Provision of Personal
      Information to Third Parties)\\n\\nThe Company does not provide personal information
      to external parties without the user's prior consent, except where required
      by law or requested through legal procedures by an investigative agency.\\n\\nArticle
      4 (Outsourcing of Personal Information Processing)\\n\\nFor the smooth provision
      of services, the Company outsources personal information processing tasks to
      external specialized companies as follows.\\n\\nGoogle Cloud: Data storage
      and server operation management\\n\\nGoogle Analytics, Firebase: Analysis of
      game usage behavior and statistical processing\\n\\nDevelopocket Edu: Customer
      inquiry response and guidance\\n\\nArticle 5 (Retention and Use Period of Personal
      Information)\\n\\nPersonal information is destroyed without delay once its
      purpose has been achieved; however, where retention is required under relevant
      laws, it is retained for the period specified below.\\n\\n- Records related
      to contracts or withdrawal of subscription: 5 years\\n\\n- Records related
      to payment and supply of goods: 5 years\\n\\n- Records related to consumer
      complaints or dispute resolution: 3 years\\n\\n- Login records: 3 months\\n\\nArticle
      6 (Procedures and Methods of Personal Information Destruction)\\n\\nPersonal
      information whose retention period has elapsed is deleted using technical methods
      that make it non-recoverable, and paper documents are shredded or incinerated
      for destruction.\\n\\nArticle 7 (Rights of Users and Legal Representatives
      and Methods of Exercising Them)\\n\\nUsers (and legal representatives of children
      under 14 years of age) may at any time view, correct, or delete (withdraw membership)
      their personal information, and may make such requests through the in-game
      settings function or the Personal Information Protection Officer.\\n\\nArticle
      8 (Installation, Operation, and Refusal of Automatic Personal Information Collection
      Devices)\\n\\nUsers may refuse the collection of advertising identifiers (IDFA,
      AAID) for personalized advertising by changing their device settings.\\n\\n-
      Android: Settings \u2192 Google \u2192 Ads \u2192 Reset advertising ID or opt
      out of ad personalization\\n\\n- iOS: Settings \u2192 Privacy \u2192 Tracking
      \u2192 Turn off \\\"Allow Apps to Request to Track\\\"\\n\\nArticle 9 (Measures
      to Ensure the Security of Personal Information)\\n\\nThe Company protects users'
      personal information through administrative and technical measures such as
      password encryption, technical countermeasures against hacking, and minimization
      and training of personnel handling personal information.\\n\\nArticle 10 (Personal
      Information Protection Officer)\\n\\n- Name: Yang Hyun-seok\\n\\n- Department:
      Developocket Edu\\n\\n- Position: Deputy General Manager\\n\\n- Email: smart@kiweb.or.kr\\n\\n-
      Phone: 02-479-4050\\n\\nArticle 11 (Duty of Notification)\\n\\nIn the event
      of any addition, deletion, or modification to this Privacy Policy, notice will
      be given through in-game announcements, etc., at least 7 days before the revision
      takes effect.\\n\\n- Announcement Date: September 17, 2025\\n\\n- Effective
      Date: September 17, 2025\""

    TextBox: 1
    name_KR: "\uB798\uB9AC"
    name_EN: Rary
    Text_KR: "\uC790\uC2E0\uC758 \uC874\uC7AC\uB97C \uC78A\uC740 \uC0AC\uB78C\uB4E4\uC774,

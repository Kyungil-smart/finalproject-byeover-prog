    TextBox: 1
    name_KR: "\uC624\uC154"
    name_EN: Ocea
    Text_KR: "\uC624, \uC5D0\uC774\uD504\uB9B4\uC591. \uBB3C\uC5B4\uBCF4\uACE0 \uC2F6\uC740\uAC8C
      \uC788\uB098? \uD3B8\uD788 \uB9D0\uD574\uBCF4\uAC8C."
    Text_EN: "Oh, Miss April. Is there something you\u2019d like to ask? Please,
      speak freely."

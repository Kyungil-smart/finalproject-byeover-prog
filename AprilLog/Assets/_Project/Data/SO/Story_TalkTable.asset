    GroupID: 3033
    TextBox: 1
    name_KR: "\uB798\uB9AC"
    name_EN: Rary
    Text_KR: "\uC784\uC758\uB85C \uC0DD\uC131\uB41C \uBC88\uAC1C\uC600\uB358\uAC70\uC9C0. "

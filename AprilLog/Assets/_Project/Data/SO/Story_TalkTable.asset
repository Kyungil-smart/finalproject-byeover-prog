    SFX: 0
  - ID: 101142
    GroupID: 3029
    TextBox: 1
    name_KR: "\uC5D0\uC774\uD504\uB9B4"
    name_EN: April
    Text_KR: "\uC9D1\uCC44\uBCF4\uB2E4 \uCEE4\uB2E4\uB780 \uACE0\uB798\uB3C4, \uC138\uC0C1\uC744
      \uB4A4\uB36E\uB294 \uD0DC\uD48D\uB3C4, \uB3C4\uB9C8\u3142...\uC6A9\uC778\uC871\uC758
      \uC678\uD615\uB3C4,"
    Text_EN: Whales that are bigger than houses, typhoons that swallow the whole
      world, and the appearance of the liza... I mean, the Dragonkin,
    portrait1: 400011
    direction1: 1
    portrait2: 0
    direction2: 0
    portrait3: 400020
    direction3: 0
    speaker: 1
    BG: 20066
    CG: 0
    BGM: 2010
    SFX: 0

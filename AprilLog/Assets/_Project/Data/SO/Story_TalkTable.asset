    SFX: 0
  - ID: 100352
    GroupID: 3011
    TextBox: 1
    name_KR: "\uC624\uC154"
    name_EN: Ocea
    Text_KR: "\uC9C4\uC8FC\uB85C\uB3C4 \uC18C\uC6A9\uC774 \uC5C6\uC5C8\uC9C0. "

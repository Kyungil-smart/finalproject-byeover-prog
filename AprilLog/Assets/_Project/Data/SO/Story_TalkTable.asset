    TextBox: 1
    name_KR: "\uB798\uB9AC"
    name_EN: Rary
    Text_KR: "\uB098\uC640 \uC5D0\uC774\uD504\uB9B4\uC740 \uB2F9\uBD84\uAC04 \uB3C4\uC11C\uAD00\uC5D0
      \uCD9C\uC11D\uD558\uB294 \uAC78\uB85C."

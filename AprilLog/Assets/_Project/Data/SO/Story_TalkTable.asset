  - ID: 101052
    GroupID: 3026
    TextBox: 1
    name_KR: "\uB798\uB9AC"
    name_EN: Rary
    Text_KR: "\uC804\uD1B5\uC744 \uC874\uC911\uD588\uB2E4\uB294 \uC758\uC9C0\uB9CC
      \uC788\uC5B4\uB3C4 \uB41C\uB2E4\uB294 \uB73B\uC73C\uB85C. "

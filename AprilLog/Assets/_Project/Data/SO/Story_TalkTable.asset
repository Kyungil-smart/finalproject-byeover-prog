    TextBox: 1
    name_KR: "\uC624\uC154"
    name_EN: Ocea
    Text_KR: "\uC6B0\uB9AC\uAC00 \uC5B4\uCC0C\uD560 \uBC14\uB97C \uBAA8\uB974\uACE0
      \uB2F9\uD558\uACE0\uB9CC \uC788\uC790..."

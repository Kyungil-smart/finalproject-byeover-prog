    TextBox: 1
    name_KR: "\uB798\uB9AC"
    name_EN: Rary
    Text_KR: "\uB9C8\uBC95\uC758 \uD798\uC744 \uADF9\uB3C4\uB85C \uC62C\uB9AC\uB294

    name_KR: "\uC5D0\uD074\uB808"
    name_EN: Ecle
    Text_KR: "\uBCF8\uB798 \uC218\uD638\uC790\uAC00 \uB418\uBA74 \uBAB8\uC758 \uC0C1\uCC98\uAC00

    TextBox: 1
    name_KR: "\uC624\uC154"
    name_EN: Ocea
    Text_KR: "\uBC18\uACBD\uC758 \uBAA8\uB4E0 \uAD6C\uC5ED\uACFC \uBAA8\uB4E0 \uC0DD\uBB3C\uC5D0
      \uB300\uD574 \uC774\uC0C1\uD604\uC0C1\uC744 \uB9C9\uB294 \uC720\uBB3C\uC774\uC5C8\uC5B4."

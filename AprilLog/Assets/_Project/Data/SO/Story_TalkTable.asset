    GroupID: 3029
    TextBox: 1
    name_KR: "\uB798\uB9AC"
    name_EN: Rary
    Text_KR: "\uB3C4\uC11C\uAD00\uC774 \uC788\uC744\uAE4C?"
    Text_EN: "Do you think there\u2019s a library around here?!"

    TextBox: 1
    name_KR: "\uC5D0\uC774\uD504\uB9B4"
    name_EN: April
    Text_KR: "\uB9C8\uBC95\uC758 \uCC45\uC7A5 \uCE78\uC5D0\uC11C \uAC19\uC740 \uC885\uB958\uC758
      \uCC45 3\uAD8C\uC744 \uBAA8\uC73C\uBA74 \uADF8 \uCC45\uC758 \uB9C8\uBC95\uC774
      \uBC1C\uB3D9\uD558\uC9C0."
    Text_EN: "If you line up three of the same books in the magic bookshelf slots,
      the spell activates. That\u2019s how it works."
    portrait1: 400010

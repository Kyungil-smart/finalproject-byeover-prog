    TextBox: 1
    name_KR: "\uC624\uC154"
    name_EN: Ocea
    Text_KR: "\"\uC774\uC57C\uAE30\uB294 \uC21C\uB9AC\uB300\uB85C \uD758\uB7EC\uAC00\uC57C\uD55C\uB2E4.\""
    Text_EN: '"Stories must follow their natural course. Always."'

    SFX: 0
  - ID: 100349
    GroupID: 3011
    TextBox: 1
    name_KR: "\uC624\uC154"
    name_EN: Ocea
    Text_KR: "\uC815\uC0AC\uC5D0\uB294 \uB0B4\uAC00 \uC544\uBC84\uC9C0\uC758 \uC778\uC815\uC744
      \uBC1B\uACE0 \uC655\uC704\uB97C \uACC4\uC2B9\uBC1B\uC740 \uAC78\uB85C \uB418\uC5B4\uC788\uC9C0\uB9CC..."
    Text_EN: The official history states that I inherited the throne after winning
      my father's approval, but...
    portrait1: 400010
    direction1: 1

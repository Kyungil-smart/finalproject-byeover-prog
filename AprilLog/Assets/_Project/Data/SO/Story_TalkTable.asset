    TextBox: 1
    name_KR: "\uC624\uC154"
    name_EN: Ocea
    Text_KR: "\uC880 \uC2DC\uAC04\uC774 \uAC78\uB9AC\uAE34 \uD588\uACE0, \uB2E4\uC18C

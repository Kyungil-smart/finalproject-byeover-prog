    SFX: 0
  - ID: 100277
    GroupID: 3007
    TextBox: 1
    name_KR: "\uC624\uC154"
    name_EN: Ocea
    Text_KR: "5\uB144\uB3C4 \uB354 \uB410\uAD70. \uB2F9\uC2DC\uC758 \uC6B0\uB9AC
      \uC544\uD2C0\uB780\uC740 \uC704\uAE30\uC5D0 \uBE60\uC838\uC788\uC5C8\uC5B4."
    Text_EN: that was more than five years ago. Atlan was really pushing its limits
      back then

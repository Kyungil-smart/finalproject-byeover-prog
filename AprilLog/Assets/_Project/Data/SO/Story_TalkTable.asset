    TextBox: 1
    name_KR: "\uC624\uC154"
    name_EN: Ocea
    Text_KR: "\uADF8 \uB4A4\uB85C \uC774\uB798\uB3C4 \uB418\uB098 \uC2F6\uC744 \uC815\uB3C4\uB85C
      \uC77C\uC774 \uC798 \uD480\uB838\uB124."

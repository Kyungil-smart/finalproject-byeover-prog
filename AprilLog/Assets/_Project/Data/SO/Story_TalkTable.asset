    TextBox: 1
    name_KR: "\uB798\uB9AC"
    name_EN: Rary
    Text_KR: "\uADFC\uB370 \uC774\uC0C1\uD558\uAC8C \uC6B0\uB9B4 \uBC18\uAE30\uB294
      \uCE5C\uAD6C\uB4E4\uC774 \uB610 \uC788\uB124. "

    TextBox: 1
    name_KR: "\uB798\uB9AC"
    name_EN: Rary
    Text_KR: "\uB3D9\uD654\uC758 \uC8FC\uC778\uACF5\uC774 \uBC14\uB00C\uBA74, \uC138\uACC4\uAC00
      \uBB34\uB108\uC9C8 \uC218\uB3C4 \uC788\uC5B4. "

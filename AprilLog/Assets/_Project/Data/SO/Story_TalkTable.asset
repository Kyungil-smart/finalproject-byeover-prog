    name_KR: "\uB798\uB9AC"
    name_EN: Rary
    Text_KR: "\uC624\uB7AB\uB3D9\uC548 \uC790\uC720\uB85C\uC6B8\uC218\uB85D \uCE68\uC2DD\uC744
      \uD37C\uB728\uB9AC\uAE30 \uC720\uB9AC\uD558\uB2C8\uAE4C."

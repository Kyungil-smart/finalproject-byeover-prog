    TextBox: 1
    name_KR: "\uC624\uC154"
    name_EN: Ocea
    Text_KR: "'\uC804\uC124\uC758 \uC9C4\uC8FC' \uD0D0\uC0AC\uB300\uC600\uC9C0."

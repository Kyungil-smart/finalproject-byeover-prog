    TextBox: 1
    name_KR: "\uD398\uC5B4"
    name_EN: Fair
    Text_KR: "\uBCF8\uB798\uB294 \uC774\uB7F4 \uC0DD\uAC01\uC740 \uC5C6\uC5C8\uC9C0\uB9CC..."

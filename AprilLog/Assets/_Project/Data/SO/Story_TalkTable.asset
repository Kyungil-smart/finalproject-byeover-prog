    name_KR: "\uC5D0\uD074\uB808"
    name_EN: Ecle
    Text_KR: "\uADF8\uB7FC \uB09C, \uBC25\uC744 \uC880 \uC900\uBE44\uD558\uACE0 \uC624\uACA0\uB2E4."

    TextBox: 1
    name_KR: "\uC5D0\uD074\uB808"
    name_EN: Ecle
    Text_KR: "\uB098\uC758 \uC774\uC57C\uAE30\uB97C \uB4E4\uC5B4\uC8FC\uACE0, \uAE30\uAEBC\uC774
      \uD574\uACB0\uD574\uC8FC\uACA0\uB2E4\uACE0 \uD588\uB2E4. "

    SFX: 0
  - ID: 101129
    GroupID: 3029
    TextBox: 1
    name_KR: "\uC5D0\uD074\uB808"
    name_EN: Ecle
    Text_KR: "\uAC70\uC758 \uB098\uB9CC \uAC00\uC11C \uAD00\uB9AC\uD558\uACE0 \uC788\uC5B4\uC11C,
      \uBB38\uC81C \uC5C6\uB2E4."
    Text_EN: Almost no one goes there but me. It's safe.
    portrait1: 0
    direction1: 0
    portrait2: 400020
    direction2: 1
    portrait3: 400070
    direction3: 0

  - ID: 101946
    GroupID: 3049
    TextBox: 1
    name_KR: "\uD398\uC5B4"
    name_EN: Fair
    Text_KR: "\uC791\uBCC4\uC758 \uC2DC\uAC04\uC774\uB2E4, \uC5D0\uC774\uD504\uB9B4. "
    Text_EN: It's time to say goodbye, April.
    portrait1: 400012
    direction1: 1
    portrait2: 0
    direction2: 0
    portrait3: 400092
    direction3: 0
    speaker: 3
    BG: 20117

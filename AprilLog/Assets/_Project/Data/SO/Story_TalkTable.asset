    GroupID: 3023
    TextBox: 1
    name_KR: "\uB798\uB9AC"
    name_EN: Rary
    Text_KR: "\uADF8 \uC911\uC559\uC5D0 \uB098\uBB34 \uD55C \uADF8\uB8E8\uAC00 \uC788\uB294\uB370,
      \uBC88\uAC1C\uB97C \uB9DE\uC544\uB3C4 \uB044\uB5A1\uC5C6\uB294 \uB098\uBB34\uC57C. "
    Text_EN: "Right in the dead center, there\u2019s this single tree that doesn\u2019t
      even flinch when it gets struck by lightning!"

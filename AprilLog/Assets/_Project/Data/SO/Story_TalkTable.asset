    TextBox: 1
    name_KR: "\uB798\uB9AC"
    name_EN: Rary
    Text_KR: "\uD070 \uC601\uD5A5\uC744 \uC8FC\uC9C0 \uC54A\uB294 \uC870\uC5F0 \uC815\uB3C4\uB294

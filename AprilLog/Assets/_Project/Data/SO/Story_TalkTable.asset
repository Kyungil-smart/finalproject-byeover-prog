    TextBox: 1
    name_KR: "\uB798\uB9AC"
    name_EN: Rary
    Text_KR: "\uC6B0\uB9AC\uB294 \uC9C4\uC8FC \uD0D0\uC0AC\uB300\uC600\uC5B4. "
